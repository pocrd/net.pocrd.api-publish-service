{% endfor %}

        com.fasterxml.jackson.core.JsonToken token = parser.currentToken();
        // 如果当前 token 不是 START_OBJECT，尝试获取下一个 token
        if (token != com.fasterxml.jackson.core.JsonToken.START_OBJECT) {
            token = parser.nextToken();
        }
        if (token != com.fasterxml.jackson.core.JsonToken.START_OBJECT) {
            throw new IllegalArgumentException("Expected JSON object, got: " + token);
        }

        while ((token = parser.nextToken()) != com.fasterxml.jackson.core.JsonToken.END_OBJECT) {
            if (token != com.fasterxml.jackson.core.JsonToken.FIELD_NAME) {
                continue;
            }
            String fieldName = parser.getCurrentName();
            token = parser.nextToken();

{% for field in fields %}
{% if loop.first %}
