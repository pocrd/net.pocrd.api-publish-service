            }
        }

        return new {{ class_name }}({% for field in fields %}{{ field.name }}{% if not loop.last %}, {% endif %}{% endfor %});
    }

    /**
     * 跳过当前 JSON 值（用于处理未知字段）
     */
    private static void skipValue(com.fasterxml.jackson.core.JsonParser parser, 
                                   com.fasterxml.jackson.core.JsonToken token) throws java.io.IOException {
        switch (token) {
            case START_OBJECT:
                while (parser.nextToken() != com.fasterxml.jackson.core.JsonToken.END_OBJECT) {
                    if (parser.currentToken() == com.fasterxml.jackson.core.JsonToken.FIELD_NAME) {
                        parser.nextToken();
                        skipValue(parser, parser.currentToken());
                    }
                }
                break;
            case START_ARRAY:
                while (parser.nextToken() != com.fasterxml.jackson.core.JsonToken.END_ARRAY) {
                    if (parser.currentToken().isStructStart()) {
                        skipValue(parser, parser.currentToken());
                    }
                }
                break;
            default:
                // 标量值，无需操作
                break;
        }
    }
}
