    /**
     * 从 JSON 字符串反序列化为实体对象
     * <p>
     * 使用 Jackson JsonParser 流式解析，零拷贝直接到字段
     */
    public static {{ class_name }} fromJson(String json) {
        if (json == null || json.isEmpty() || json.equals("null")) {
            return null;
        }

        try (com.fasterxml.jackson.core.JsonParser parser = 
                new com.fasterxml.jackson.core.JsonFactory().createParser(json)) {
            return parseFromJson(parser);
        } catch (java.io.IOException e) {
            throw new IllegalArgumentException("Failed to parse JSON: " + json, e);
        }
    }

    /**
