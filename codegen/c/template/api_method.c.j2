{% else %}
char* {{ class_name | to_snake_case }}_build_request_body(const {{ class_name }}_request_t *req) {
    if (!req) return strdup("");
{% if method.parameters | length == 1 %}
    {% set param = method.parameters[0] %}
    {% if param.containerType == 'list' %}
    /* Single list parameter - serialize the list directly */
    cJSON *json = cJSON_CreateArray();
    {{ prefix }}_list_node_t *node = req->{{ param.name }}->head;
    while (node) {
        {% if param.type is entity_type %}
        cJSON_AddItemToArray(json, {{ param.type | entity_func_prefix }}_to_cjson(({{ param.type | to_c_type }})node->data));
        {% elif param.type == 'string' %}
        cJSON_AddItemToArray(json, cJSON_CreateString((char*)node->data));
        {% elif param.type == 'bool' %}
        cJSON_AddItemToArray(json, cJSON_CreateBool((cJSON_bool)*(bool*)node->data));
        {% elif param.type == 'int' %}
        cJSON_AddItemToArray(json, cJSON_CreateNumber(*(int*)node->data));
        {% elif param.type == 'long' %}
        cJSON_AddItemToArray(json, cJSON_CreateString((char*)node->data));
        {% else %}
        cJSON_AddItemToArray(json, cJSON_CreateString((char*)node->data));
        {% endif %}
        node = node->next;
    }
    char *str = cJSON_PrintUnformatted(json);
    cJSON_Delete(json);
    return str;
    {% elif param.containerType == 'set' %}
    /* Single set parameter - serialize the set directly */
    cJSON *json = cJSON_CreateArray();
    {{ prefix }}_set_node_t *node = req->{{ param.name }}->head;
    while (node) {
         {% if param.type is entity_type %}
        cJSON_AddItemToArray(json, {{ param.type | entity_func_prefix }}_to_cjson(({{ param.type | to_c_type }})node->data));
        {% elif param.type == 'string' %}
        cJSON_AddItemToArray(json, cJSON_CreateString((char*)node->data));
        {% elif param.type == 'bool' %}
        cJSON_AddItemToArray(json, cJSON_CreateBool((cJSON_bool)*(bool*)node->data));
        {% elif param.type == 'int' %}
        cJSON_AddItemToArray(json, cJSON_CreateNumber(*(int*)node->data));
        {% elif param.type == 'long' %}
        cJSON_AddItemToArray(json, cJSON_CreateString((char*)node->data));
        {% else %}
        cJSON_AddItemToArray(json, cJSON_CreateString((char*)node->data));
        {% endif %}
        node = node->next;
    }
    char *str = cJSON_PrintUnformatted(json);
    cJSON_Delete(json);
    return str;
    {% elif param.type is entity_type %}
    /* Single entity parameter - use entity's to_json */
    return {{ param.type | entity_func_prefix }}_to_json(req->{{ param.name }});
    {% else %}
    /* Single primitive parameter */
    cJSON *json = cJSON_CreateObject();
    {% if param.type == 'string' %}
    cJSON_AddStringToObject(json, "{{ param.name }}", req->{{ param.name }});
    {% elif param.type == 'bool' %}
    cJSON_AddBoolToObject(json, "{{ param.name }}", req->{{ param.name }});
    {% else %}
    cJSON_AddNumberToObject(json, "{{ param.name }}", req->{{ param.name }});
    {% endif %}
    char *str = cJSON_PrintUnformatted(json);
    cJSON_Delete(json);
    return str;
    {% endif %}
{% else %}
    /* Multiple parameters - build JSON object */
    cJSON *json = cJSON_CreateObject();
{% for param in method.parameters %}
    {% if param.containerType == 'list' %}
    if (req->{{ param.name }}) {
        cJSON *{{ param.name }}_arr = cJSON_CreateArray();
        {{ prefix }}_list_node_t *node = req->{{ param.name }}->head;
        while (node) {
            {% if param.type is entity_type %}
            cJSON_AddItemToArray(json, {{ param.type | entity_func_prefix }}_to_cjson(({{ param.type | to_c_type }})node->data));
            {% elif param.type == 'string' %}
            cJSON_AddItemToArray(json, cJSON_CreateString((char*)node->data));
            {% elif param.type == 'bool' %}
            cJSON_AddItemToArray(json, cJSON_CreateBool((cJSON_bool)*(bool*)node->data));
            {% elif param.type == 'int' %}
            cJSON_AddItemToArray(json, cJSON_CreateNumber(*(int*)node->data));
            {% elif param.type == 'long' %}
            cJSON_AddItemToArray(json, cJSON_CreateString((char*)node->data));
            {% else %}
            cJSON_AddItemToArray(json, cJSON_CreateString((char*)node->data));
            {% endif %}
            node = node->next;
        }
        cJSON_AddItemToObject(json, "{{ param.name }}", {{ param.name }}_arr);
    }
    {% elif param.containerType == 'set' %}
    if (req->{{ param.name }}) {
        cJSON *{{ param.name }}_arr = cJSON_CreateArray();
        {{ prefix }}_set_node_t *node = req->{{ param.name }}->head;
        while (node) {
            {% if param.type is entity_type %}
            cJSON_AddItemToArray(json, {{ param.type | entity_func_prefix }}_to_cjson(({{ param.type | to_c_type }})node->data));
            {% elif param.type == 'string' %}
            cJSON_AddItemToArray(json, cJSON_CreateString((char*)node->data));
            {% elif param.type == 'bool' %}
            cJSON_AddItemToArray(json, cJSON_CreateBool((cJSON_bool)*(bool*)node->data));
            {% elif param.type == 'int' %}
            cJSON_AddItemToArray(json, cJSON_CreateNumber(*(int*)node->data));
            {% elif param.type == 'long' %}
            cJSON_AddItemToArray(json, cJSON_CreateString((char*)node->data));
            {% else %}
            cJSON_AddItemToArray(json, cJSON_CreateString((char*)node->data));
            {% endif %}
            node = node->next;
        }
        cJSON_AddItemToObject(json, "{{ param.name }}", {{ param.name }}_arr);
    }
    {% elif param.type is entity_type %}
    if (req->{{ param.name }}) {
        cJSON_AddItemToObject(json, "{{ param.name }}", {{ param.type | entity_func_prefix }}_to_cjson(req->{{ param.name }}));
    }
    {% elif param.type == 'string' %}
    if (req->{{ param.name }}) {
        cJSON_AddStringToObject(json, "{{ param.name }}", req->{{ param.name }});
    }
    {% elif param.type == 'bool' %}
    cJSON_AddBoolToObject(json, "{{ param.name }}", req->{{ param.name }});
    {% else %}
    cJSON_AddNumberToObject(json, "{{ param.name }}", req->{{ param.name }});
    {% endif %}
{% endfor %}
    char *str = cJSON_PrintUnformatted(json);
    cJSON_Delete(json);
    return str;
{% endif %}
}
{% endif %}

char* {{ class_name | to_snake_case }}_build_url(const char *base_url) {
    if (!base_url) return NULL;
    /* Build URL: base_url/dapi/interface/method */
    size_t len = strlen(base_url) + strlen("/dapi/{{ interface_name }}/{{ method.name }}") + 1;
    char *url = (char*)malloc(len);
    if (url) {
        snprintf(url, len, "%s/dapi/{{ interface_name }}/{{ method.name }}", base_url);
    }
    return url;
}
